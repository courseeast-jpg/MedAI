# Never commit
.env
data/
*.db
*.db-shm
*.db-wal
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.DS_Store
*.egg-info/
dist/
build/
.venv/
venv/
artifacts/

# Validation runs copy holdout/real input PDFs into per-phase report
# subdirectories named "archive/" and "review/". Those copies may
# contain PHI and must not be committed.
reports/**/archive/
reports/**/review/
reports/**/*.pdf
reports/**/*.png
reports/**/*.jpg
reports/**/*.jpeg
reports/**/*.tif
reports/**/*.tiff
reports/**/*.bmp
reports/**/*.webp
reports/**/local_filename_mapping_PRIVATE.json
reports/phase54_operator_review_feedback/operator_feedback_PRIVATE.json
reports/phase54_operator_review_feedback/*raw*notes*

# Real operator validation inputs may contain PHI. Keep only the placeholder.
real_validation_input/*
!real_validation_input/.gitkeep

# Full corpus inventory inputs may contain PHI. Keep only the placeholder.
full_corpus_input/*
!full_corpus_input/.gitkeep
reports/phase57_full_corpus_inventory_audit/local_filename_mapping_PRIVATE.json
reports/phase57_full_corpus_inventory_audit/operator_notes_PRIVATE.json
reports/phase57_full_corpus_inventory_audit/phase57_safe_progress_checkpoint.json
reports/phase72_operator_feedback_collection/operator_feedback_PRIVATE.json

# CKA private sanitization/mapping files — never tracked
reports/**/*_PRIVATE.json
reports/**/private_*_PRIVATE.json
